APP_NAME=ibkr-exec-bot
APP_ENV=dev
LOG_LEVEL=INFO

IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
IBKR_ACCOUNT=

DATABASE_URL=sqlite:///./ibkr_exec.db

LIVE_TRADING=false
ACK_LIVE_TRADING=
DRY_RUN=true

MIN_STOP_DISTANCE=0.01
DEFAULT_RISK_DOLLARS=100.0
MAX_POSITIONS=5
MAX_NOTIONAL=100000.0
MAX_DAILY_LOSS=1000.0
MAX_ORDERS_PER_MINUTE=30
MAX_TRADES_PER_SYMBOL_PER_DAY=3

IBKR_MAX_REQUESTS_PER_SECOND=45
IBKR_PACING_WINDOW_SECONDS=1.0
WATCHDOG_STALE_AFTER_SECONDS=30
WATCHDOG_CHECK_INTERVAL_SECONDS=5
MEMORY_LOG_INTERVAL_SECONDS=300
